{
  "name": "@opengeometry/kernel-three",
  "author": "Vishwajeet Vinayak Mane",
  "license": "MPL-2.0",
  "version": "2.0.1",
  "description": "OpenGeometry Kernel for Three.js",
  "main": "index.js",
  "scripts": {
    "dev-example-three": "vite --config ./vite.examples.config.mjs",
    "build-example-three": "vite build --config ./vite.examples.config.mjs && node ./scripts/copy-wasm-assets.mjs",
    "preview-example-three": "vite preview --config ./vite.examples.config.mjs",
    "docs:api": "typedoc --options ./typedoc.json",
    "docs:api:watch": "typedoc --options ./typedoc.json --watch"
  },
  "keywords": [
    "opengeometry",
    "three",
    "geometry"
  ],
  "dependencies": {
    "@opengeometry/openmaths": "^0.2.3"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "typedoc": "^0.28.14"
  }
}
